{
  "name": "discord-music-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "postinstall": "node -e \"process.platform=='win32'||require('fs').existsSync('yt-dlp')||require('child_process').execSync('curl -sL https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp -o yt-dlp',{stdio:'inherit'})||require('fs').chmodSync('yt-dlp',0o755)\"",
    "build": "tsc",
    "register": "tsx src/commands/registry.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "ffmpeg-static": "^5.3.0",
    "opusscript": "^0.0.8",
    "yt-search": "^2.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "~5.7.0"
  }
}
